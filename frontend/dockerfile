# Imagen base compatible con Node 20+
FROM node:20-alpine

# Directorio de trabajo
WORKDIR /app

# Copiamos package.json y lock si existe
COPY package*.json ./

# Instalamos dependencias
RUN npm install

# Copiamos el resto del proyecto
COPY . .

# Exponemos el puerto de Vite
EXPOSE 5173

# Comando por defecto
CMD ["npm", "run", "dev", "--", "--host"]
